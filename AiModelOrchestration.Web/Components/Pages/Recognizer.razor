@page "/recognizer"
@using AiModelOrchestration.Web.Model
@using AiModelOrchestration.Web.Services
@using Microsoft.Extensions.AI
@using OllamaSharp
@using System.Text
@inject IWebHostEnvironment Environment
@inject ILogger<Recognizer> Logger
@inject ImageService ImageService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Receipt Recognizer</PageTitle>

<h1>Receipt Assistant</h1>

<p>Upload and process receipt images to extract line items and pricing information.</p>

<div style="margin-bottom: 12px; display: flex; align-items: center; gap: 12px;">
    <label for="runsInput" style="white-space: nowrap;">Consistency Test Runs:</label>
    <input id="runsInput" type="number" min="1" max="10" @bind="consistencyRuns" disabled="@isProcessing" style="width: 60px;" />
    <button @onclick="() => ProcessReceipt(selectedImage)" disabled="@(string.IsNullOrEmpty(selectedImage) || isProcessing)">Process</button>
</div>

<button onclick="document.getElementById('fileInput').click()">Click to upload</button>
<InputFile id="fileInput" OnChange="LoadFile" accept=".jpg,.png" style="display:none" multiple />

@if (!images.Any())
{
    <p>No images found in the folder.</p>
}
else
{
    <ul>
        @foreach (var image in images)
        {
            <li @onclick="() => SelectImage(image)"
                style="cursor:pointer; padding:4px; @(selectedImage == image ? "font-weight:bold; color:blue;" : "")">
                🧾 @image
            </li>
        }
    </ul>
}

@if (!string.IsNullOrEmpty(selectedImage))
{
    <div style="margin-top:16px;">
        <h4>@selectedImage</h4>
        <img src="@($"Uploads/{selectedImage}")"
             alt="@selectedImage"
             style="max-width:600px; max-height:450px; border:1px solid #ccc; border-radius:8px;" />
    </div>
}

@if (!string.IsNullOrEmpty(processResult))
{
    <div style="margin-top:32px; padding:16px; background-color:#f5f5f5; border:1px solid #ddd; border-radius:8px; white-space:pre-wrap; font-family:monospace; font-size:12px;">
        <h4>Receipt Processing Result:</h4>
        <p>@processResult</p>
    </div>
}

@code 
{
    private List<string> images = new();
    private string selectedImage = string.Empty;
    private string processResult = string.Empty;
    private bool isProcessing = false;
    private int consistencyRuns = 3;

    protected override void OnInitialized()
    {
        images = ImageService.GetImagesFromFolder("Uploads");
        selectedImage = images.FirstOrDefault() ?? string.Empty;
    }

    private void SelectImage(string imageName)
    {
        selectedImage = imageName;
        StateHasChanged();
    }

    [Inject(Key = ServiceKeys.Llama)]
    public required IChatClient LlamaClient { get; set; }

    private ChatMessage systemMessage = new ChatMessage(
        ChatRole.System,
        """
        You are a receipt parsing assistant. Extract all line items from the receipt image.
        For each line item, extract the name, quantity, unit price, and total price.
        Quantity can be a decimal number (e.g. weight in kg like 0.550 or 1.105).
        Extract the subtotal which is the final total amount shown on the receipt.
        IMPORTANT: Read every digit exactly as printed on the receipt.
        Pay very close attention to each decimal digit - do NOT round or approximate.
        For example, if the receipt shows 1.105, report exactly 1.105, not 1.1 or 1.2.
        Verify that quantity * unitPrice = totalPrice for each line item.
        Don't invent items that aren't on the receipt.
        Receipt is in polish language. 
        Polish diacritics that are used on the receipt just replace with latin letters, 
        so for example "ł" write as "l", "ą" write as "a", "ę" write as "e", "ó" write as "o" etc.

        DECIMAL FORMAT: Receipts may use different number formats depending on locale.
        - Some use period as decimal separator: 7,499.00 (seven thousand four hundred ninety-nine)
        - Some use comma as decimal separator: 7.499,00 (seven thousand four hundred ninety-nine)
        First, detect which format the receipt uses by examining the numbers on it.
        Then, always output numbers in the JSON using a period as the decimal separator.
        For example: 7499.00, not 7.499,00 or 7,499.00.

        RECEIPT COMPONENTS:
        Seller's name and address
        Seller's Tax Identification Number (NIP)
        Cash register number
        Date and time of sale
        Receipt number
        Names of purchased goods/services
        Quantity and unit price
        Gross value (price including VAT)
        VAT rate (e.g., 23%, 8%, 5%, 0%, exempt)
        Total amount to pay
        Method of payment (cash/card)
        Fiscal logo and unique cash register number

        NOTES: The receipt may include information about taxable sales,
        the individual letters indicate the VAT rates as follows:
        Letter "A": Standard VAT rate (23% or 22%) (Sp.op.A).
        Letter "B": First reduced VAT rate (8% or 7%) (Sp.op.B).
        Letter "C": Second reduced VAT rate (5%) (Sp.op.C).
        Letter "D": Third reduced VAT rate (0%) (Sp.op.D).
        Letter "E": VAT exemption (Sp.op.E)

        NOT INCLUDE (Skip comma separated values and also theirs variations):
        Sp.op.A, Sprzed. opod. PTU A, PTU A,
        Sp.op.B, Sprzed. opod. PTU B, PTU B,
        Sp.op.C, Sprzed. opod. PTU C, PTU C,
        Sp.op.D, Sprzed. opod. PTU D, PTU D,
        Sp.op.E, Sprzed. opod. PTU E, PTU E,
        SUMA PTU, Podatek PTU
        ZAPLACONO GOTOWKA PLN, ZAPŁACONO GOTOWKA PLN
        """
    );

    private ChatMessage message = new ChatMessage(
        ChatRole.User,
        """
        Extract all line items from this receipt.
        Respond in JSON format with this structure:
        {
            "items": 
            [
                {
                    "name": "item name",
                    "quantity": 1.500,
                    "unitPrice": 0.00,
                    "totalPrice": 0.00
                }
            ],
            "subtotal": 0.00
        }
        """
    );

    private async Task ProcessReceipt(string fileName)
    {
        isProcessing = true;
        StateHasChanged();

        var stringBuilder = new StringBuilder();
        try
        {
            message.AdditionalProperties = new() { ["receipt-schema.json"] = File.ReadAllText("Metadata/receipt-schema.json") };
            message.Contents.Add(new DataContent(File.ReadAllBytes($"wwwroot/Uploads/{fileName}"), $"image/{Path.GetExtension(fileName).Substring(1)}"));

            stringBuilder.AppendLine();
            stringBuilder.AppendLine($"--- Consistency test ({consistencyRuns} runs) ---");

            var results = new List<Receipt>();
            for (int i = 0; i < consistencyRuns; i++)
            {
                stringBuilder.AppendLine();
                stringBuilder.AppendLine($"Run {i + 1}...");
                var testResponse = await LlamaClient.GetResponseAsync<Receipt>(
                    [systemMessage, message],
                    new ChatOptions { Temperature = 0 },
                    true);

                if (testResponse.Result is { } receipt)
                {
                    receipt.ToJson();

                    results.Add(receipt);
                    stringBuilder.AppendLine($"  Items: {receipt.Items.Count}, Subtotal: {receipt.Subtotal:C}");
                    foreach (var item in receipt.Items)
                    {
                        stringBuilder.AppendLine(
                            $"    {item.Name} - Qty: {item.Quantity} x {item.UnitPrice:C} = {item.TotalPrice:C}");
                    }
                }
            }

            stringBuilder.AppendLine();
            stringBuilder.AppendLine("--- Comparison ---");

            var baseline = results[0];
            for (int i = 1; i < results.Count; i++)
            {
                bool match = 
                    baseline.Subtotal == results[i].Subtotal
                    && baseline.Items.Count == results[i].Items.Count
                    && baseline.Items.Zip(results[i].Items).All(
                        pair =>
                        pair.First.Name == pair.Second.Name
                        && pair.First.Quantity == pair.Second.Quantity
                        && pair.First.UnitPrice == pair.Second.UnitPrice
                        && pair.First.TotalPrice == pair.Second.TotalPrice);

                stringBuilder.AppendLine($"  Run 1 vs Run {i + 1}: {(match ? "MATCH" : "DIFFERENT")}");
            }
        }
        finally
        {
            processResult = stringBuilder.ToString();
            isProcessing = false;
            StateHasChanged();
        }
    }

    private long maxFileSize = 100 * 1024 * 1024;
    private int maxAllowedFiles = 3;
    private string[] allowedTypes = new[] { "image/jpeg", "image/png" };

    private async Task LoadFile(InputFileChangeEventArgs eventArguments)
    {
        if (eventArguments.FileCount > maxAllowedFiles)
        {
            return;
        }
        foreach (var file in eventArguments.GetMultipleFiles(maxAllowedFiles))
        {
            if (!allowedTypes.Contains(file.ContentType))
            {
                return;
            }
            var extension = file.ContentType switch
            {
                "image/jpeg" => "jpg",
                "image/png" => "png",
                _ => "bin"
            };
            var fileName = $"{Path.GetRandomFileName().Replace(".", string.Empty)}.{extension}";
            var uploadPath = Path.Combine(Environment.WebRootPath, "Uploads");
            Directory.CreateDirectory(uploadPath);
            uploadPath = Path.Combine(uploadPath, fileName);

            try
            {
                await using var stream = new FileStream(uploadPath, FileMode.Create);
                await file.OpenReadStream(maxFileSize).CopyToAsync(stream);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Error when processing selected file");
            }

            Navigation.NavigateTo(Navigation.Uri, true);
        }
    }
}
