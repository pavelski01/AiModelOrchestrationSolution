{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [ "Items", "Subtotal" ],
  "properties": {
    "Items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [ "Name", "Quantity", "UnitPrice", "TotalPrice" ],
        "properties": {
          "Name": { "type": "string" },
          "Quantity": {
            "type": "number",
            "minimum": 0
          },
          "UnitPrice": {
            "type": "number",
            "minimum": 0
          },
          "TotalPrice": {
            "type": "number",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "Subtotal": {
      "type": "number",
      "minimum": 0
    }
  },
  "additionalProperties": false
}